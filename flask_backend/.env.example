# ── Flask ────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=change-me-before-production

# ── Server ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000

# ── Model ────────────────────────────────────────────────────────────
# Paths relative to project root
MODEL_PATH=models/tomato_disease_resnet50.pth
METADATA_PATH=models/class_metadata.json

# ── Inference ─────────────────────────────────────────────────────────
TOP_K=5                  # how many predictions to return
IMG_SIZE=224             # must match training config
MAX_CONTENT_LENGTH=8     # max upload size in MB

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
